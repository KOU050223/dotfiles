source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# 指定したパスでターミナルを開く
newtab() {
  # 引数があればそれを、なければ現在ディレクトリ
  local target
  if [ -n "$1" ]; then
    # 相対パスも絶対パスも OK にする
    target="$(cd "$1" 2>/dev/null && pwd)" || {
      echo "no such directory: $1" >&2
      return 1
    }
  else
    target="$PWD"
  fi

  osascript <<EOF
tell application "Terminal"
  activate
  tell application "System Events" to tell process "Terminal" to keystroke "t" using command down
  do script "cd '$target'" in front window
end tell
EOF
}

alias newtarm='newtab'

# fd (高速find代替) + fzf でディレクトリジャンプ
unalias cdf 2>/dev/null
cdf() {
  local dir
  dir=$(fd --type d 2>/dev/null | fzf +m --preview 'tree -C {} | head-200')
  [[ -n $dir ]] && cd "$dir"
}

